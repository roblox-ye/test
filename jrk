local originalProperties = {}
local optimizationConnection = nil
local isOptimized = false

local function OptimizeSinglePart(v)

    if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("UnionOperation") then
        if not originalProperties[v] then
            originalProperties[v] = { Material = v.Material, CastShadow = v.CastShadow }
        end
        v.Material = Enum.Material.SmoothPlastic 
        v.CastShadow = false 

    elseif v:IsA("Decal") or v:IsA("Texture") then
        if not originalProperties[v] then
            originalProperties[v] = { Transparency = v.Transparency }
        end
        v.Transparency = 1 

    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
        if not originalProperties[v] then
            originalProperties[v] = { Enabled = v.Enabled }
        end
        v.Enabled = false
    end
end

local function OptimizeGame()
    if isOptimized then return end
    isOptimized = true

    local lighting = game:GetService("Lighting")
    local terrain = workspace:FindFirstChildOfClass("Terrain")

    if terrain then
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 0
    end

    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    lighting.GlobalShadows = false
    lighting.FogEnd = 9e9
    lighting.Brightness = 1 

    for _, v in ipairs(lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("ColorCorrectionEffect") or v:IsA("BloomEffect") or v:IsA("DepthOfFieldEffect") then
            v.Enabled = false
        end
    end

    task.spawn(function()
        local descendants = workspace:GetDescendants()
        for i, v in ipairs(descendants) do
            OptimizeSinglePart(v)
            if i % 200 == 0 then task.wait() end
        end
    end)

    optimizationConnection = workspace.DescendantAdded:Connect(function(v)
        OptimizeSinglePart(v)
    end)

    if getgenv().Ye_Notify then Ye_Notify("性能优化", "功能已开启，正在处理中...", 3) end
end 

local function RestoreGame()
    if not isOptimized then return end
    isOptimized = false

    if optimizationConnection then
        optimizationConnection:Disconnect()
        optimizationConnection = nil
    end

    local lighting = game:GetService("Lighting")
    local terrain = workspace:FindFirstChildOfClass("Terrain")

    if terrain then
        terrain.WaterWaveSize = 0.15 
        terrain.WaterWaveSpeed = 10
        terrain.WaterReflectance = 1
        terrain.WaterTransparency = 0.3
    end

    settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
    lighting.GlobalShadows = true
    lighting.FogEnd = 100000
    lighting.Brightness = 2 

    for _, v in ipairs(lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("ColorCorrectionEffect") or v:IsA("BloomEffect") or v:IsA("DepthOfFieldEffect") then
            v.Enabled = true
        end
    end

    task.spawn(function()
        local count = 0
        for obj, props in pairs(originalProperties) do
            count = count + 1
            pcall(function()
                if obj and obj.Parent then
                    for propName, propValue in pairs(props) do
                        obj[propName] = propValue
                    end
                end
            end)
            if count % 200 == 0 then task.wait() end
        end
        originalProperties = {}
        if getgenv().Ye_Notify then Ye_Notify("恢复画质", "画质复原", 3) end
    end)
end

