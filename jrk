local buttonHistory = {} 

local function LoadButtons()
    local files = listfiles(folderName)
    for _, file in ipairs(files) do
        local name = file:match("([^\\/]+)%.txt$") or file

        if not buttonHistory[name] then
            buttonHistory[name] = true
            ListSection:Button("传送: " .. name, function()
                if isfile(file) then
                    local content = readfile(file)
                    local split = string.split(content, ", ")
                    local targetPos = Vector3.new(tonumber(split[1]), tonumber(split[2]), tonumber(split[3]))
                    game.Players.LocalPlayer.Character:SetPrimaryPartCFrame(CFrame.new(targetPos + Vector3.new(0, 3, 0)))
                else
                    game:GetService("StarterGui"):SetCore("SendNotification", {Title = "提示", Text = "文件已不存在"})
                end
            end)
        end
    end
end

