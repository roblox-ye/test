local function createHighlightESP(player)
    if not Settings.Highlight then return end
    if player.Character then
        if player.Character:FindFirstChild("HighlightESP") then player.Character.HighlightESP:Destroy() end
        local highlight = Instance.new("Highlight")
        highlight.Name = "HighlightESP"
        highlight.Adornee = player.Character
        highlight.FillTransparency = 0.5
        highlight.FillColor = player.TeamColor and player.TeamColor.Color or Color3.new(1, 0, 0)
        highlight.OutlineColor = Color3.new(1, 1, 1)
        highlight.Parent = player.Character
    end
end

local function GetDrawings(player)
    if not ESP_Cache[player] then ESP_Cache[player] = { Drawings = {} } end
    local d = ESP_Cache[player].Drawings

    if not d.Tracer then d.Tracer = Drawing.new("Line"); d.Tracer.Thickness = 1.5 end
    if not d.Box then d.Box = Drawing.new("Square"); d.Box.Thickness = 1.5; d.Box.Filled = false end
    if not d.HealthBg then d.HealthBg = Drawing.new("Line"); d.HealthBg.Thickness = 3; d.HealthBg.Color = Color3.new(0,0,0) end
    if not d.HealthBar then d.HealthBar = Drawing.new("Line"); d.HealthBar.Thickness = 2 end
    
    if not d.NameText then 
        d.NameText = Drawing.new("Text")
        d.NameText.Center = true
        d.NameText.Outline = true 
        d.NameText.Font = 2 
    end

    return d
end

RunService.RenderStepped:Connect(function()
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local d = ESP_Cache[player] and ESP_Cache[player].Drawings
        if not d then continue end

        local char = player.Character
        local isValid = char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0
        local onScreen, pos = false, nil

        if isValid and ShouldShow(player) then
            local hrp = char.HumanoidRootPart
            local dist = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)
            
            -- 判断是否在滑块设定的距离范围内
            if dist <= Settings.MaxDistance then
                pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)

                if onScreen then
                    local size = char:GetExtentsSize()
                    local top = Camera:WorldToViewportPoint((hrp.CFrame * CFrame.new(0, size.Y/2, 0)).p)
                    local bottom = Camera:WorldToViewportPoint((hrp.CFrame * CFrame.new(0, -size.Y/2, 0)).p)
                    local height = math.abs(top.Y - bottom.Y)
                    local width = height * 0.6

                    local boxPos = Vector2.new(pos.X - width/2, top.Y)
                    local boxSize = Vector2.new(width, height)
                    local espColor = player.TeamColor and player.TeamColor.Color or Color3.new(1, 0.2, 0.2)

                    if Settings.Tracer then
                        d.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        d.Tracer.To = Vector2.new(pos.X, bottom.Y)
                        d.Tracer.Color = espColor
                        d.Tracer.Visible = true
                    else d.Tracer.Visible = false end

                    if Settings.BoxESP then
                        d.Box.Position = boxPos
                        d.Box.Size = boxSize
                        d.Box.Color = espColor
                        d.Box.Visible = true
                    else d.Box.Visible = false end

                    if Settings.HealthBar then
                        local healthRatio = char.Humanoid.Health / char.Humanoid.MaxHealth
                        local barHeight = height * healthRatio
                        local barX = boxPos.X - 5

                        d.HealthBg.From = Vector2.new(barX, top.Y)
                        d.HealthBg.To = Vector2.new(barX, bottom.Y)
                        d.HealthBg.Visible = true

                        d.HealthBar.From = Vector2.new(barX, bottom.Y)
                        d.HealthBar.To = Vector2.new(barX, bottom.Y - barHeight)
                        d.HealthBar.Color = Color3.new(1 - healthRatio, healthRatio, 0)
                        d.HealthBar.Visible = true
                    else 
                        d.HealthBg.Visible = false; d.HealthBar.Visible = false 
                    end

                    if Settings.NameESP then
                        d.NameText.Text = string.format("%s [%dm]", player.Name, dist)
                        d.NameText.Position = Vector2.new(boxPos.X + (width / 2), top.Y - (Settings.TextSize + 2)) 
                        d.NameText.Color = espColor
                        d.NameText.Size = Settings.TextSize -- 实时应用滑块调整的字体大小
                        d.NameText.Visible = true
                    else
                        d.NameText.Visible = false
                    end
                end
            end
        end

        if not onScreen or not isValid or not ShouldShow(player) or (char and char:FindFirstChild("HumanoidRootPart") and math.floor((Camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude) > Settings.MaxDistance) then
            for _, drawing in pairs(d) do drawing.Visible = false end
        end
    end
end)

