                        radius * math.sin(phi) * math.sin(theta)
                    )

                elseif shape == "Heart" then

                    local t = (i / totalParts) * math.pi * 2 + timeOffset
                    local scale = 1.2
                    local x = 16 * math.sin(t)^3
                    local y = 13 * math.cos(t) - 5 * math.cos(2*t) - 2 * math.cos(3*t) - math.cos(4*t)

                    targetOffset = CFrame.Angles(0, timeOffset * 0.5, 0) * Vector3.new(x * scale, y * scale, 0)

                elseif shape == "Triangle" then

                    local p = ((i / totalParts) * 3 + (timeOffset * 0.5)) % 3
                    local r = 20
                    local p1, p2
                    if p < 1 then
                        p1 = Vector3.new(0, r, 0); p2 = Vector3.new(-r, -r, 0)
                    elseif p < 2 then
                        p1 = Vector3.new(-r, -r, 0); p2 = Vector3.new(r, -r, 0)
                    else
                        p1 = Vector3.new(r, -r, 0); p2 = Vector3.new(0, r, 0)
                    end
                    local fraction = p % 1

                    targetOffset = CFrame.Angles(0, timeOffset * 0.5, 0) * p1:Lerp(p2, fraction)
                end

                local targetPos = center + targetOffset

                part.AssemblyLinearVelocity = (targetPos - part.Position) * 10

                part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                part.CanCollide = false
            end
        end)
    else

        if getgenv().ViolentBHConnection then
            getgenv().ViolentBHConnection:Disconnect()
            getgenv().ViolentBHConnection = nil
        end

        for _, part in ipairs(workspace:GetDescendants()) do
            if part:IsA("BasePart") and not part.Anchored then
                pcall(function()
                    part.AssemblyLinearVelocity = Vector3.new(math.random(-60,60), -150, math.random(-60,60))
                    part.CanCollide = true
                end)
            end
        end
    end
end)

