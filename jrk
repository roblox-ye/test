local PartMap = {
    ["头"] = {"Head"},
    ["胸"] = {"UpperTorso", "Torso"},
    ["左手"] = {"LeftHand", "Left Arm"},
    ["右手"] = {"RightHand", "Right Arm"},
    ["左腿"] = {"LeftFoot", "Left Leg"},
    ["右腿"] = {"RightFoot", "Right Leg"}
}

local function GetTargetPart(char)
    local parts = PartMap[Settings.TargetPart]
    for _, pName in ipairs(parts) do
        local p = char:FindFirstChild(pName)
        if p then return p end
    end
    return char:FindFirstChild("HumanoidRootPart")
end

local function IsVisible(targetPart)
    if not Settings.WallCheck then return true end
    local origin = Cam.CFrame.Position
    local dir = targetPart.Position - origin

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {plr.Character, Cam}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.IgnoreWater = true

    local hit = workspace:Raycast(origin, dir, rayParams)
    if hit and hit.Instance then
        if hit.Instance:IsDescendantOf(targetPart.Parent) then
            return true
        end
        return false
    end
    return true
end

local function GetBestTarget()
    local bestTarget = nil
    local bestValue = math.huge
    local screenCenter = Vector2.new(Cam.ViewportSize.X / 2, Cam.ViewportSize.Y / 2)

    for _, p in ipairs(Players:GetPlayers()) do
        if p == plr then continue end

        if Settings.TeamCheck and plr.Team ~= nil and p.Team == plr.Team then continue end

        local char = p.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        local tPart = GetTargetPart(char)

        if hum and hum.Health > 0 and root and tPart then
            local pos, onScreen = Cam:WorldToViewportPoint(tPart.Position)
            if not onScreen then continue end

            local distToMouse = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude

            if distToMouse <= Settings.FOV then

                if not IsVisible(tPart) then continue end

                if Settings.TargetMode == "准心最近" then
                    if distToMouse < bestValue then
                        bestValue = distToMouse
                        bestTarget = {Player = p, Part = tPart}
                    end
                elseif Settings.TargetMode == "距离最近" then
                    local distToPlayer = (plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and (plr.Character.HumanoidRootPart.Position - root.Position).Magnitude) or math.huge
                    if distToPlayer < bestValue then
                        bestValue = distToPlayer
                        bestTarget = {Player = p, Part = tPart}
                    end
                elseif Settings.TargetMode == "血量最低" then
                    if hum.Health < bestValue then
                        bestValue = hum.Health
                        bestTarget = {Player = p, Part = tPart}
                    end
                end
            end
        end
    end

    return bestTarget
end

