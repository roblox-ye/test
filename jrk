local function createDynamicVignette(guiParent)
    local vignetteFrames = {}

    local layoutData = {
        {UDim2.new(1, 0, 0.3, 0), UDim2.new(0.5, 0, 0, 0), Vector2.new(0.5, 0), 90},  
        {UDim2.new(1, 0, 0.3, 0), UDim2.new(0.5, 0, 1, 0), Vector2.new(0.5, 1), 270}, 
        {UDim2.new(0.3, 0, 1, 0), UDim2.new(0, 0, 0.5, 0), Vector2.new(0, 0.5), 0},   
        {UDim2.new(0.3, 0, 1, 0), UDim2.new(1, 0, 0.5, 0), Vector2.new(1, 0.5), 180}, 
    }

    for _, data in ipairs(layoutData) do
        local frame = Instance.new("Frame", guiParent)
        frame.Size = data[1]
        frame.Position = data[2]
        frame.AnchorPoint = data[3]
        frame.BackgroundColor3 = Color3.new(0, 0, 0)
        frame.BorderSizePixel = 0
        frame.BackgroundTransparency = 1 
        frame.ZIndex = 10 

        local gradient = Instance.new("UIGradient", frame)
        gradient.Rotation = data[4]
        gradient.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1)  
        })
        table.insert(vignetteFrames, frame)
    end

    return vignetteFrames
end

local function tweenVignetteTransparency(frames, targetTransparency, duration, easingStyle)
    easingStyle = easingStyle or Enum.EasingStyle.Sine
    local info = TweenInfo.new(duration, easingStyle, Enum.EasingDirection.Out)
    for _, frame in ipairs(frames) do
        TweenService:Create(frame, info, {BackgroundTransparency = targetTransparency}):Play()
    end
end

local function playGTATeleportAnimation(targetCFrame)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local hrp = char.HumanoidRootPart
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local camera = workspace.CurrentCamera

    local startPos = hrp.Position
    local targetX = targetCFrame.Position.X
    local targetZ = targetCFrame.Position.Z
    local baseTargetY = targetCFrame.Position.Y 

    if humanoid then humanoid.WalkSpeed = 0 end
    hrp.Anchored = true
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    camera.CameraType = Enum.CameraType.Scriptable

    local level1 = 80   
    local level2 = 400  
    local level3 = 1200 

    local blurEffect = Instance.new("BlurEffect", Lighting)
    blurEffect.Size = 0 

    local vignetteGui = Instance.new("ScreenGui", player.PlayerGui)
    vignetteGui.IgnoreGuiInset = true 
    vignetteGui.Name = "GTA Teleport Vignette"
    local vignetteFrames = createDynamicVignette(vignetteGui) 

    task.spawn(function()
        TweenService:Create(blurEffect, TweenInfo.new(1), {Size = 6}):Play()

        flashEffect()
        tweenCamera(camera, 0.7, CFrame.new(startPos + Vector3.new(0, level1, 0), startPos))
        task.wait(0.3) 

        flashEffect()
        tweenCamera(camera, 0.8, CFrame.new(startPos + Vector3.new(0, level2, 0), startPos))
        task.wait(0.3)

        flashEffect()
        tweenCamera(camera, 1.0, CFrame.new(startPos + Vector3.new(0, level3, 0), startPos))
        task.wait(0.4)

        local hiddenPos = Vector3.new(targetX, baseTargetY - 50, targetZ)
        hrp.CFrame = CFrame.new(hiddenPos)

        flashEffect()
        local skyCamPos = Vector3.new(targetX, baseTargetY + level3, targetZ)
        tweenCamera(camera, 1.6, CFrame.new(skyCamPos, Vector3.new(targetX, baseTargetY, targetZ)))

        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        raycastParams.FilterDescendantsInstances = {char}

        local safeY = baseTargetY
        local foundGround = false

        for i = 1, 20 do
            local rayOrigin = Vector3.new(targetX, baseTargetY + 1000, targetZ)
            local rayDirection = Vector3.new(0, -2000, 0)
            local rayResult = workspace:Raycast(rayOrigin, rayDirection, raycastParams)

            if rayResult then
                safeY = rayResult.Position.Y + 4 
                foundGround = true
                break
            end
            task.wait(0.1)
        end

        if not foundGround then
            safeY = math.max(safeY, 50) 
        end

        local targetPos = Vector3.new(targetX, safeY, targetZ)
        local safeTargetCFrame = CFrame.new(targetPos)

        hrp.CFrame = safeTargetCFrame

        tweenVignetteTransparency(vignetteFrames, 0.5, 0.5) 
        flashEffect()
        tweenCamera(camera, 0.9, CFrame.new(targetPos + Vector3.new(0, level2, 0), targetPos))
        task.wait(0.3)

        flashEffect()
        tweenCamera(camera, 0.8, CFrame.new(targetPos + Vector3.new(0, level1, 0), targetPos))
        task.wait(0.3)

        tweenVignetteTransparency(vignetteFrames, 1, 0.6, Enum.EasingStyle.Quad) 
        TweenService:Create(blurEffect, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = 0}):Play() 

        flashEffect()
        local endCamCFrame = safeTargetCFrame * CFrame.new(0, 3, 12)
        tweenCamera(camera, 0.7, CFrame.new(endCamCFrame.Position, targetPos))

        camera.CameraType = Enum.CameraType.Custom
        if humanoid then camera.CameraSubject = humanoid end
        hrp.Anchored = false 
        if humanoid then humanoid.WalkSpeed = 16 end

        blurEffect:Destroy()
        vignetteGui:Destroy()
    end)
end

