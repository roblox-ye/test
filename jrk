local function ApplyAnim(char)
    if not getgenv().Ye_AnimEnabled then return end
    local animate = char:WaitForChild("Animate", 10)
    local hum = char:WaitForChild("Humanoid", 10)
    local animator = hum:WaitForChild("Animator", 10)
    local pack = animPacks[getgenv().Ye_SelectedAnim]
    if not animate or not animator or not pack then return end
    local function set(folder, name, id)
        pcall(function()
            if animate:FindFirstChild(folder) then
                local obj = animate[folder]:FindFirstChild(name) or animate[folder]:FindFirstChildOfClass("Animation")
                if obj then obj.AnimationId = "rbxassetid://" .. id end
            end
        end)
    end
    if pack.i1 then set("idle", "Animation1", pack.i1) end
    if pack.i2 then set("idle", "Animation2", pack.i2) end
    if pack.w then set("walk", "WalkAnim", pack.w) end
    if pack.r then set("run", "RunAnim", pack.r) end
    if pack.j then set("jump", "JumpAnim", pack.j) end
    if pack.c then set("climb", "ClimbAnim", pack.c) end
    if pack.f then set("fall", "FallAnim", pack.f) end
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do track:Stop(0) end
end

