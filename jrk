local function ApplyLeg()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    if char:FindFirstChild("YeFakeLeg") then char.YeFakeLeg:Destroy() end
    if getgenv().Ye_LegEnabled then
        if not getgenv().Ye_LegSt then
            getgenv().Ye_LegSt = {}
            local parts = hum.RigType == Enum.HumanoidRigType.R15 and {"RightUpperLeg", "RightLowerLeg", "RightFoot"} or {"Right Leg"}
            for _, pN in ipairs(parts) do
                local p = char:FindFirstChild(pN)
                if p then
                    getgenv().Ye_LegSt[p] = p.Transparency
                    p.Transparency = 1
                    for _, c in ipairs(p:GetDescendants()) do
                        if c:IsA("BasePart") or c:IsA("Decal") or c:IsA("Texture") or c:IsA("MeshPart") then
                            getgenv().Ye_LegSt[c] = c.Transparency
                            c.Transparency = 1
                        end
                    end
                end
            end
            for _, acc in ipairs(char:GetChildren()) do
                if acc:IsA("Accessory") and acc:FindFirstChild("Handle") then
                    local weld = acc.Handle:FindFirstChildOfClass("Weld") or acc.Handle:FindFirstChildOfClass("Motor6D")
                    if weld and weld.Part1 and string.find(weld.Part1.Name, "Right") and string.find(weld.Part1.Name, "Leg") then
                        getgenv().Ye_LegSt[acc.Handle] = acc.Handle.Transparency
                        acc.Handle.Transparency = 1
                    end
                end
            end
        end
        local attach = hum.RigType == Enum.HumanoidRigType.R15 and char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("Right Leg")
        local data = legOptions[getgenv().Ye_SelectedLeg]
        if attach and data then
            local fL = Instance.new("Part", char)
            fL.Name = "YeFakeLeg"
            fL.Size = Vector3.new(1, 1, 1)
            fL.CanCollide = false
            fL.Massless = true
            fL.Transparency = 0
            local m = Instance.new("SpecialMesh", fL)
            m.MeshType = Enum.MeshType.FileMesh
            m.MeshId = data.mesh
            m.TextureId = data.tex
            m.Scale = data.scale
            local w = Instance.new("Weld", fL)
            w.Part0 = attach
            w.Part1 = fL
            w.C0 = hum.RigType == Enum.HumanoidRigType.R15 and data.offset_R15 or data.offset_R6
        end
    else
        if getgenv().Ye_LegSt then
            for o, t in pairs(getgenv().Ye_LegSt) do 
                if o and o.Parent then o.Transparency = t end 
            end
            getgenv().Ye_LegSt = nil
        end
    end
end

local function ApplyFace()
    local char = LocalPlayer.Character
    local f = char and char:FindFirstChild("Head") and (char.Head:FindFirstChild("face") or char.Head:FindFirstChild("Face"))
    if not f then return end
    if getgenv().Ye_FaceEnabled then
        if not getgenv().Ye_OldFTex then getgenv().Ye_OldFTex = f.Texture end
        f.Texture = faceOptions[getgenv().Ye_SelectedFace]
    else
        if getgenv().Ye_OldFTex then 
            f.Texture = getgenv().Ye_OldFTex 
            getgenv().Ye_OldFTex = nil
        end
    end
end

local function ApplyHat()
    local char = LocalPlayer.Character
