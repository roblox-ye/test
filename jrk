local function FindUniversalPart(character, targetName)
    if not character then return nil end

    local exactPart = character:FindFirstChild(targetName)
    if exactPart and exactPart:IsA("BasePart") then
        return exactPart
    end

    local lowerTarget = targetName:lower()
    for _, part in ipairs(character:GetChildren()) do
        if part:IsA("BasePart") and part.Name:lower():match(lowerTarget) then
            return part
        end
    end

    return nil
end

local function SaveOriginal(player, part)
    if not OriginalProps[player] then OriginalProps[player] = {} end
    if not OriginalProps[player][part.Name] then
        OriginalProps[player][part.Name] = {
            Size = part.Size,
            Transparency = part.Transparency,
            CanCollide = part.CanCollide
        }
    end
end

local function RestorePlayer(player)
    if OriginalProps[player] and player.Character then
        for partName, props in pairs(OriginalProps[player]) do
            local part = player.Character:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                part.Size = props.Size
                part.Transparency = props.Transparency
                part.CanCollide = props.CanCollide
            end
        end
    end
end

